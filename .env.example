# --- LLM (Gemini via LiteLLM) ---
GEMINI_API_KEY=your-gemini-api-key-here
# Optional key rotation (comma-separated, first = primary). Each key is its own
# quota project: a model is exhausted across ALL keys before falling back.
GEMINI_API_KEYS=
MODEL_MAIN=gemini/gemini-3.5-flash
MODEL_CHEAP=gemini/gemini-3.1-flash-lite
# LLM-as-judge for /evaluate — deliberately a different model than MODEL_MAIN
MODEL_JUDGE=gemini/gemini-2.5-flash
# Tried in order (best first) when a model's budget is spent or it returns 429
MODEL_FALLBACKS=gemini/gemini-3-flash-preview,gemini/gemini-2.5-flash,gemini/gemini-3.1-flash-lite,gemini/gemini-2.5-flash-lite
# Client-side budgets matching the AI Studio free-tier dashboard
RPM_MAIN=5
RPD_MAIN=20
RPM_CHEAP=15
RPD_CHEAP=500

# --- Auth ---
# REQUIRED: the api refuses to start on this placeholder or anything <16 chars.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
# Comma-separated JWT subjects allowed on admin endpoints: GET /sessions,
# reading any user's session by key, POST /ingest, DELETE /documents/{id}.
# Everyone else gets 403.
ADMIN_USERNAMES=demo

# --- Service ports (host side) ---
API_PORT=8000
UI_PORT=7860

# --- Embedding / reranking ---
EMBEDDING_DEVICE=cpu
# CPU default (identical hit rate, ~25x faster); use BAAI/bge-reranker-v2-m3 on GPU
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EMBED_BATCH_SIZE=8

# --- Chat / retrieval tuning ---
HISTORY_WINDOW_TURNS=6
MIN_RERANK_SCORE=0.25

# --- Ingestion ---
# Upload size cap in MB — an abuse guard against multi-GB uploads, not a page
# limit: 200 MB fits text PDFs of tens of thousands of pages.
MAX_UPLOAD_MB=200

# --- Session store ---
REDIS_URL=redis://localhost:6379/0

# --- Optional local Ollama fallback (local dev only, never in Docker) ---
OLLAMA_FALLBACK_ENABLED=false
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_k_m
OLLAMA_BASE_URL=http://localhost:11434
